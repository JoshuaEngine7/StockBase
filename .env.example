# ─── Authentication ───────────────────────────────────────────────
# Required: plain-text password (used as fallback if no hash is set)
ADMIN_PASS=your_admin_password_here

# Optional: bcrypt hashes (generate with: node generate-hash.js)
# ADMIN_HASH=$2b$10$...
# VIEWER_PASS=your_viewer_password
# VIEWER_HASH=$2b$10$...

# ─── Server ──────────────────────────────────────────────────────
PORT=3000

# ─── Backup ──────────────────────────────────────────────────────
# Optional: network path for backup copies (e.g. \\server\share\backups)
# BACKUP_RED=
